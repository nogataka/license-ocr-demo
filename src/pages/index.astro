---
// No server-side logic needed — all processing is client-side
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>運転免許証リーダー</title>
    <script is:inline define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
      if (typeof window !== "undefined" && !window.crossOriginIsolated) {
        const s = document.createElement("script");
        s.src = baseUrl + (baseUrl.endsWith("/") ? "" : "/") + "coi-serviceworker.min.js";
        document.head.appendChild(s);
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --color-bg: #f3f4f6;
        --color-surface: #ffffff;
        --color-border: #e5e7eb;
        --color-text: #111827;
        --color-text-secondary: #6b7280;
        --color-text-muted: #9ca3af;
        --color-accent: #2563eb;
        --color-accent-hover: #1d4ed8;
        --color-accent-light: #eff6ff;
        --color-success: #16a34a;
        --sidebar-width: 360px;
        --radius: 12px;
        --transition: 180ms ease;
      }

      body {
        font-family: "Noto Sans JP", -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--color-bg);
        color: var(--color-text);
        line-height: 1.6;
        min-height: 100dvh;
      }

      /* ========= Dashboard Layout ========= */
      .dashboard {
        display: grid;
        grid-template-columns: var(--sidebar-width) 1fr;
        min-height: 100dvh;
      }

      /* -- Left Sidebar -- */
      .sidebar {
        background: var(--color-surface);
        border-right: 1px solid var(--color-border);
        padding: 24px 20px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        overflow-y: auto;
        position: sticky;
        top: 0;
        height: 100dvh;
      }

      .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--color-border);
      }
      .sidebar-brand .brand-icon {
        width: 36px;
        height: 36px;
        background: var(--color-accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .sidebar-brand .brand-icon svg {
        width: 20px;
        height: 20px;
        color: #fff;
      }
      .sidebar-brand h1 {
        font-size: 15px;
        font-weight: 700;
        color: var(--color-text);
        line-height: 1.3;
      }
      .sidebar-brand p {
        font-size: 11px;
        color: var(--color-text-muted);
        margin-top: 1px;
      }

      /* -- Sidebar Card -- */
      .side-card {
        background: var(--color-bg);
        border-radius: var(--radius);
        padding: 16px;
      }
      .side-card-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-text-muted);
        margin-bottom: 12px;
      }

      /* -- Drop zone (sidebar) -- */
      #drop-zone {
        position: relative;
        border-radius: 10px;
        padding: 28px 16px;
        text-align: center;
        background: linear-gradient(135deg, #eef2ff 0%, #e8f0fe 100%);
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        overflow: hidden;
      }
      #drop-zone::before {
        content: "";
        position: absolute;
        inset: 5px;
        border: 2px dashed rgba(37, 99, 235, 0.2);
        border-radius: 8px;
        pointer-events: none;
        transition: border-color 0.2s ease;
      }
      #drop-zone:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
      }
      #drop-zone:hover::before {
        border-color: rgba(37, 99, 235, 0.45);
      }
      #drop-zone.dragover {
        transform: scale(1.01);
        box-shadow: 0 8px 24px rgba(37, 99, 235, 0.15);
        background: linear-gradient(135deg, #dbeafe 0%, #c7d2fe 100%);
      }
      #drop-zone.dragover::before {
        border-color: var(--color-accent);
        border-style: solid;
      }
      #drop-zone .drop-icon-wrap {
        width: 48px;
        height: 48px;
        margin: 0 auto 10px;
        background: var(--color-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 3px 10px rgba(37, 99, 235, 0.25);
        transition: transform 0.25s ease;
      }
      #drop-zone:hover .drop-icon-wrap { transform: translateY(-2px); }
      #drop-zone.dragover .drop-icon-wrap { transform: scale(1.08); }
      #drop-zone .drop-icon-wrap svg {
        width: 22px;
        height: 22px;
        color: #fff;
      }
      #drop-zone .drop-title {
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text);
        margin-bottom: 2px;
      }
      #drop-zone .drop-sub {
        font-size: 11px;
        color: var(--color-text-muted);
      }
      #drop-zone .drop-badge {
        display: inline-block;
        margin-top: 10px;
        padding: 3px 12px;
        border-radius: 20px;
        background: rgba(37, 99, 235, 0.08);
        font-size: 11px;
        font-weight: 500;
        color: var(--color-accent);
      }
      #file-input { display: none; }

      /* -- Edit controls (sidebar button) -- */
      #edit-controls {
        display: none;
      }
      #edit-controls.visible {
        display: block;
      }

      /* -- Edit section (main area) -- */
      #edit-section {
        display: none;
      }
      #edit-section.visible {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
      }
      .edit-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .edit-card-header {
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text-secondary);
        border-bottom: 1px solid var(--color-border);
      }
      .edit-card-body {
        padding: 12px;
      }
      .edit-card-body canvas {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 6px;
      }
      #src-canvas { cursor: crosshair; }

      /* -- Progress (sidebar) -- */
      #progress-section {
        display: none;
        background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 100%);
        border: 1px solid rgba(37, 99, 235, 0.1);
        border-radius: 10px;
        padding: 16px;
        position: relative;
        overflow: hidden;
      }
      #progress-section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--color-accent), #7c3aed, var(--color-accent));
        background-size: 200% 100%;
        animation: progress-shimmer 2s ease-in-out infinite;
      }
      @keyframes progress-shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }
      .progress-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
      }
      .progress-spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(37, 99, 235, 0.15);
        border-top-color: var(--color-accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      #progress-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--color-text);
        flex: 1;
      }
      #progress-pct {
        font-size: 12px;
        font-weight: 700;
        color: var(--color-accent);
        font-variant-numeric: tabular-nums;
      }
      .progress-track {
        background: rgba(37, 99, 235, 0.08);
        border-radius: 6px;
        height: 8px;
        overflow: hidden;
      }
      .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--color-accent), #5b8dee);
        border-radius: 6px;
        width: 0%;
        transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
        position: relative;
      }
      .progress-fill::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%);
        background-size: 200% 100%;
        animation: bar-shine 1.5s ease-in-out infinite;
      }
      @keyframes bar-shine {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
      }

      /* -- Sidebar info -- */
      .sidebar-notice {
        font-size: 11px;
        line-height: 1.6;
        color: var(--color-text-muted);
        padding: 0 4px;
      }

      .sidebar-spacer { flex: 1; }

      /* -- Buttons -- */
      .btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        padding: 11px 20px;
        border: none;
        border-radius: 10px;
        background: var(--color-accent);
        color: #fff;
        cursor: pointer;
        font-family: inherit;
        font-size: 14px;
        font-weight: 600;
        transition: background var(--transition), transform var(--transition);
      }
      .btn-primary:hover { background: var(--color-accent-hover); }
      .btn-primary:active { transform: scale(0.98); }
      .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
      .btn-primary svg { width: 16px; height: 16px; }

      .btn-small {
        padding: 6px 12px;
        border: 1px solid var(--color-border);
        border-radius: 6px;
        background: var(--color-surface);
        cursor: pointer;
        font-family: inherit;
        font-size: 12px;
        font-weight: 500;
        color: var(--color-text-secondary);
        transition: background var(--transition);
      }
      .btn-small:hover { background: var(--color-bg); }

      .btn-reset {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        width: 100%;
        padding: 10px 16px;
        border: 1px solid var(--color-border);
        border-radius: 10px;
        background: var(--color-surface);
        cursor: pointer;
        font-family: inherit;
        font-size: 13px;
        font-weight: 500;
        color: var(--color-text-secondary);
        transition: background var(--transition), border-color var(--transition);
      }
      .btn-reset:hover {
        background: var(--color-bg);
        border-color: var(--color-text-muted);
      }
      .btn-reset svg { width: 15px; height: 15px; }

      /* ========= Right Main Area ========= */
      .main-area {
        padding: 28px 32px;
        overflow-y: auto;
      }

      /* -- Empty state -- */
      .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        text-align: center;
        color: var(--color-text-muted);
      }
      .empty-state .empty-icon {
        width: 80px;
        height: 80px;
        margin-bottom: 20px;
        color: var(--color-border);
      }
      .empty-state h2 {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-text-secondary);
        margin-bottom: 6px;
      }
      .empty-state p {
        font-size: 13px;
        max-width: 300px;
      }

      /* -- Result section (main) -- */
      #result-section {
        display: none;
      }
      #result-section.visible {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
      }
      #result-section .result-footer {
        grid-column: 1 / -1;
      }

      .result-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        overflow: hidden;
      }
      .result-card-header {
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 600;
        color: var(--color-text-secondary);
        border-bottom: 1px solid var(--color-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .result-card-body {
        padding: 4px 16px;
      }

      #result-canvas {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 6px;
      }

      /* -- Fields -- */
      .field-row {
        display: flex;
        align-items: baseline;
        padding: 10px 0;
        border-bottom: 1px solid var(--color-border);
      }
      .field-row:last-child { border-bottom: none; }
      .field-label {
        width: 100px;
        flex-shrink: 0;
        font-size: 12px;
        font-weight: 600;
        color: var(--color-text-muted);
      }
      .field-value {
        flex: 1;
        font-size: 15px;
        font-weight: 500;
        color: var(--color-text);
      }
      .field-value.empty {
        color: var(--color-text-muted);
        font-weight: 400;
        font-size: 13px;
      }

      /* -- Debug -- */
      .debug-toggle {
        cursor: pointer;
        color: var(--color-text-muted);
        font-size: 12px;
        user-select: none;
      }
      #text-output {
        white-space: pre-wrap;
        font-size: 12px;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin-top: 8px;
      }

      .reset-area {
        text-align: center;
        margin-top: 16px;
      }

      /* ========= Responsive ========= */
      @media (max-width: 800px) {
        :root { --sidebar-width: 100%; }
        .dashboard {
          grid-template-columns: 1fr;
        }
        .sidebar {
          position: relative;
          height: auto;
          border-right: none;
          border-bottom: 1px solid var(--color-border);
        }
        .main-area {
          padding: 20px 16px;
        }
        #result-section.visible {
          grid-template-columns: 1fr;
        }
        #edit-section.visible {
          grid-template-columns: 1fr;
        }
        .empty-state { min-height: 30vh; }
      }

      @media (max-width: 480px) {
        .field-label { width: 80px; }
        .field-value { font-size: 14px; }
      }
    </style>
  </head>
  <body>
    <div class="dashboard">
      <!-- ===== Left Sidebar ===== -->
      <aside class="sidebar">
        <div class="sidebar-brand">
          <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="14" rx="2"/>
              <path d="M7 15h0M17 15h0"/>
            </svg>
          </div>
          <div>
            <h1>免許証リーダー</h1>
            <p>ブラウザ完結型 OCR</p>
          </div>
        </div>

        <div class="side-card">
          <div class="side-card-title">画像アップロード</div>
          <div id="drop-zone">
            <div class="drop-icon-wrap">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/>
                <path d="M12 12v9"/>
                <path d="m16 16-4-4-4 4"/>
              </svg>
            </div>
            <p class="drop-title">ドロップまたはクリック</p>
            <p class="drop-sub">免許証の画像を選択</p>
            <span class="drop-badge">JPEG / PNG</span>
            <input type="file" id="file-input" accept="image/*" />
          </div>
        </div>

        <section id="edit-controls">
          <button class="btn-primary" id="btn-correct-ocr">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 11 12 14 22 4"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>
            </svg>
            読み取り開始
          </button>
        </section>

        <section id="progress-section">
          <div class="progress-header">
            <div class="progress-spinner"></div>
            <div id="progress-label">準備中...</div>
            <div id="progress-pct">0%</div>
          </div>
          <div class="progress-track">
            <div class="progress-fill" id="progress-bar"></div>
          </div>
        </section>

        <button class="btn-reset" id="reset-btn" style="display: none">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
            <path d="M3 3v5h5"/>
          </svg>
          別の画像を読み取る
        </button>

        <div class="sidebar-spacer"></div>

        <p class="sidebar-notice">
          画像はサーバーに送信されません。初回のみAIモデル（約77MB）をダウンロードします。
        </p>
      </aside>

      <!-- ===== Right Main Area ===== -->
      <main class="main-area">
        <section id="edit-section">
          <div class="edit-card">
            <div class="edit-card-header">四隅をドラッグで調整</div>
            <div class="edit-card-body">
              <canvas id="src-canvas"></canvas>
            </div>
          </div>
          <div class="edit-card">
            <div class="edit-card-header">補正プレビュー</div>
            <div class="edit-card-body">
              <canvas id="preview-canvas"></canvas>
            </div>
          </div>
        </section>

        <div class="empty-state" id="empty-state">
          <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="16" rx="3"/>
            <path d="M8 21h8"/>
            <path d="M12 19v2"/>
            <circle cx="12" cy="11" r="3"/>
          </svg>
          <h2>読み取り結果がここに表示されます</h2>
          <p>左のパネルから免許証の画像をアップロードしてください</p>
        </div>

        <section id="result-section">
          <div class="result-card">
            <div class="result-card-header">検出結果</div>
            <div class="result-card-body" style="padding: 12px" id="canvas-container">
              <canvas id="result-canvas"></canvas>
            </div>
          </div>
          <div class="result-card">
            <div class="result-card-header">
              読み取り結果
              <button class="btn-small" id="copy-btn">コピー</button>
            </div>
            <div class="result-card-body">
              <div id="fields-output"></div>
            </div>
          </div>
          <div class="result-footer">
            <details style="margin-top: 8px">
              <summary class="debug-toggle">生テキスト（デバッグ用）</summary>
              <div id="text-output"></div>
            </details>
          </div>
        </section>
      </main>
    </div>

    <script>
      import "../app.ts";
    </script>
  </body>
</html>
